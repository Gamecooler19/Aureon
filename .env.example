# =============================================================================
# Blu3scr33n - Music  ·  ACE-Step 1.5
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# =============================================================================

# ── Model Configuration ─────────────────────────────────────────────────────
# Diffusion model preset (acestep-v15-turbo | acestep-v15)
ACESTEP_CONFIG_PATH=acestep-v15-turbo

# Language-model checkpoint name
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-0.6B

# LLM backend (pt | nano-vllm)
ACESTEP_LM_BACKEND=pt

# Whether to initialise the LLM at startup (auto | true | false)
ACESTEP_INIT_LLM=auto

# Compute device (auto | cuda | cpu | mps | xpu)
ACESTEP_DEVICE=auto

# Skip model loading on startup (true | false)
ACESTEP_NO_INIT=false

# Model download source (auto | huggingface | modelscope)
ACESTEP_DOWNLOAD_SOURCE=auto

# ── Server ───────────────────────────────────────────────────────────────────
# Host port exposed on the Docker host
HOST_PORT=3297

# Port inside the container (also used by healthcheck)
ACESTEP_API_PORT=3297

# Maximum queued generation tasks
ACESTEP_QUEUE_MAXSIZE=100

# Number of generation worker threads
ACESTEP_QUEUE_WORKERS=1

# ── Authentication ───────────────────────────────────────────────────────────
# API key for protecting endpoints. Leave empty or comment out to disable auth.
# ACESTEP_API_KEY=your-secret-key-here

# ── Logging ──────────────────────────────────────────────────────────────────
# Max size per log file (Docker json-file driver)
LOG_MAX_SIZE=50m

# Number of rotated log files to keep
LOG_MAX_FILE=5

# ── Audio Output ─────────────────────────────────────────────────────────────
# Persistent directory for saving generated audio tracks.
# Every successfully generated track is copied here with a human-readable name.
# In Docker this is bind-mounted to ./Audio on the host.
# Default (local dev): <project_root>/Audio
# Default (Docker):    /app/Audio
# AUDIO_OUTPUT_DIR=/app/Audio
